<IfModule mod_rewrite.c>
  RewriteEngine On

  # Let real files/directories be served directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback (React Router)
  RewriteRule ^ index.html [L]
</IfModule>

# Optional hardening
Options -Indexes
