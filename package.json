{
  "name": "location-benne-occitanie-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "cross-env NODE_ENV=development node server/index.js",
    "dev:full": "concurrently \"npm:dev:server\" \"npm:dev\"",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "build": "vite build && vite build --ssr src/entry-server.jsx --outDir .ssr --emptyOutDir && node scripts/postbuild.mjs && node scripts/redact-service-address.mjs",
    "preview": "vite preview",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && c8 --all --include=src/seo/**/*.js --include=src/data/**/*.js --include=src/api/contactProvider.js --check-coverage --lines=80 --branches=80 --functions=80 --statements=80 --reporter=text node --test"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "compression": "^1.8.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "mailersend": "^2.8.0",
    "nodemailer": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "c8": "^11.0.0",
    "concurrently": "^9.2.4",
    "cross-env": "^10.1.0",
    "vite": "^6.4.3"
  }
}
